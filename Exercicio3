Construir um algoritmo que leia um número inteiro e imprime a 	sequência:
– 1, 2, 4, 8, 16, 32, 64, 128, 256, 512, 1024. . .
– enquanto o valor da sequência for menor ou igual ao número lido.
./

mport java.util.Scanner;

public class Exercicio3{
    public static void main(String[] args) {
        Scanner entrada = new Scanner(System.in);
        
        // 1. Ler o número inteiro (limite da sequência)
        System.out.println("Digite um número inteiro:");
        int limite = entrada.nextInt();
        
        // 2. Inicializar a variável da sequência com o primeiro valor (1)
        int valorSequencia = 1;
        
        // 3. Estrutura de repetição while
        // O loop continua enquanto o valor for menor ou igual ao número lido
        while (valorSequencia <= limite) {
            System.out.print(valorSequencia + " ");
            
            // 4. Atualizar o valor para o próximo da sequência (dobro)
            valorSequencia = valorSequencia * 2;
        }
        
        entrada.close();
    }
}
