/*Nataly Pessoa de Paula Cruz
Faça um algoritmo que leia dez números inteiros e positivos
– mostre o menor entre eles.
*/
import java.util.Scanner;

public class Exercicio6 {
    public static void main(String[] args) {
        Scanner entrada = new Scanner(System.in);
        int contador = 1, numero, menor = Integer.MAX_VALUE;

        while (contador <= 10) {
            System.out.println("Digite o " + contador + "º número positivo:");
            numero = entrada.nextInt();
            
            if (numero < menor) {
                menor = numero;
            }
            contador++;
        }
        System.out.println("O menor número digitado foi: " + menor);
        entrada.close();
    }
}
